# Supabase konfiguration
# Från Project URL
SUPABASE_URL=https://ditt-id.supabase.co

# Från "service_role" (Secret keys sektionen)
SUPABASE_SERVICE_ROLE_KEY=kopiera_service_role_nyckeln_här

# Från "JWT Settings" längre ner på samma sida
SUPABASE_JWT_SECRET=kopiera_jwt_secret_här

# Din databasanslutningssträng (Transaction Pooler)
NODE_ENV=development or production
# Development  → unsafe-eval allowed (Vite HMR needs it)
# Production   → unsafe-eval blocked (strict and secure)

# Server
PORT=8080
SupaBasePassword = Lösenordet_för_supabase